export interface ReflectionGroup {
  id: string;
  studio_id: string;
  skill_id: string | null;
  mentor_id: string;
  name: string;
  description: string;
  visibility: 'public' | 'private';
  created_at: string;
  updated_at: string;
}

export interface ReflectionGroupMember {
  id: string;
  group_id: string;
  user_id: string;
  role: 'member' | 'mentor';
  joined_at: string;
  status: 'active' | 'left';
}

export interface Reflection {
  id: string;
  user_id: string;
  skill_id: string | null;
  studio_id: string | null;
  group_id: string | null;
  content: string;
  rating?: number;
  hours_spent?: number;
  is_public: boolean;
  created_at: string;
}

export interface LearnerProgress {
  user_id: string;
  full_name: string;
  email: string;
  skills_progress: number;
  completed_tasks: number;
  total_tasks: number;
  reflections_count: number;
  last_activity: string;
}
